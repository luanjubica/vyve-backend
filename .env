# Vyve Backend Environment Variables
# Copy this file to .env and update with your values

# Environment
ENV=development
PORT=8080
APP_URL=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=vyve
DB_PASSWORD=vyve
DB_NAME=vyve_dev
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=25
DB_MAX_IDLE_CONNECTIONS=5
DB_CONNECTION_MAX_LIFETIME=5m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h

# AWS Configuration (Production)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=vyve-production

# MinIO Configuration (Development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# Amplitude Analytics
AMPLITUDE_KEY=70c87fea876e44803342a9a6cde64796

# Firebase Cloud Messaging
FCM_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URL=http://localhost:8080/auth/linkedin/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URL=http://localhost:8080/auth/apple/callback

# Email Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vyve.app
SMTP_USE_TLS=false

# Security & Compliance
DB_ENCRYPTION=false
ENCRYPTION_KEY=your-32-byte-encryption-key-here
EU_DATA_RESIDENCY=false
ENABLE_AUDIT_LOG=true

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=1m

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
SENTRY_DSN=

# Feature Flags
FEATURE_AI_INSIGHTS=false
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_SOCIAL_AUTH=true
FEATURE_DATA_EXPORT=true

# API Keys for future AI features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Monitoring
PROMETHEUS_ENABLED=false
METRICS_PORT=9090

# Docker Registry (for deployment)
ECR_REGISTRY=
DOCKER_REGISTRY=

# Deployment
DEPLOY_HOST=
DEPLOY_USER=ec2-user
DEPLOY_KEY_PATH=~/.ssh/vyve-key.pem